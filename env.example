SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Supabase Storage Configuration
# Storage buckets will be created automatically: assignments, course-materials, course-thumbnails

# Notes Summarizer Configuration
# Required for the Notes Summarizer feature
# Set SUMMARY_API_KEY to your provider API key (e.g., OpenAI)
SUMMARY_API_KEY=your_summarization_api_key_here
# Optional overrides
SUMMARY_API_PROVIDER=openai
SUMMARY_MODEL=gpt-3.5-turbo
SUMMARY_MAX_INPUT_CHARS=12000